// -*- mode: jsonc -*-
{
  "height": 30,
  "spacing": 0,
  "margin-top": 6,
  "margin-left": 10,
  "margin-right": 10,

  "modules-left": ["custom/launcher", "hyprland/workspaces"],
  "modules-center": [],
  "modules-right": ["group/status", "clock", "custom/power"],

  "group/status": {
    "orientation": "horizontal",
    "modules": [
      "cpu",
      "memory",
      "temperature",
      "bluetooth",
      "pulseaudio",
      "network",
      "hyprland/language",
      "idle_inhibitor",
      "group/tray-drawer",
      "custom/notification",
    ],
  },

  "group/tray-drawer": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 400,
      "children-class": "tray-item",
      "transition-left-to-right": false,
    },
    "modules": [
      "custom/tray-toggle",
      "tray",
    ],
  },
  "custom/tray-toggle": {
    "format": "َ°…پ",
    "tooltip": false,
  },

  "custom/launcher": {
    "format": "",
    "tooltip": false,
    "on-click": "wofi --show drun",
  },
  "custom/power": {
    "format": "َ°گ¥",
    "tooltip": false,
    "on-click": "wlogout",
  },

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
  },

  "cpu": {
    "format": "َ°»  {usage}%",
    "tooltip": false,
    "interval": 5,
  },
  "memory": {
    "format": "َ°چ› {percentage}%",
    "interval": 5,
  },
  "temperature": {
    "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
    "input-filename": "temp1_input",
    "critical-threshold": 85,
    "format": "َ°”ڈ {temperatureC}آ°C",
    "format-icons": ["", "", ""],
  },
  "bluetooth": {
    // "format": "َ°‚¯ {status}",
    // "format-connected": "َ°‚± {device_alias}",
    // "format-disabled": "َ°‚¯",
    // "format-off": "َ°‚¯",
    "format-on": "َ°‚¯",
    "format-off": "َ°‚²",
    "format-disabled": "", // an empty format will hide the module
    "format-connected": "َ°‚±â€‰{num_connections}",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "blueman-manager",
  },
  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{icon}  {volume}%",
    "format-bluetooth-muted": "َ°…¶ {icon} {format_source}",
    "format-muted": "َ°–پ  {volume}%",
    "format-source": "{volume}% ",
    "format-source-muted": "",
    "format-icons": {
      "headphone": "",
      "hands-free": "َ°‚‘",
      "headset": "َ°‚‘",
      "phone": "",
      "portable": "",
      "car": "",
      "default": ["َ°•¼", "َ°•½", "َ°•¾"],
    },
    "on-click": "pavucontrol",
  },
  "network": {
    "format-wifi": "َ°–©  {essid} {signalStrength}%",
    "format-ethernet": "َ°ˆ€ Ethernet",
    "tooltip-format": "{ifname}",
    "format-linked": "{ifname} (No IP) َ°ٹ—",
    "format-disconnected": "Disconnected âڑ ",
    "on-click": "nm-connection-editor",
  },
  "hyprland/language": {
    "format": "َ°ŒŒ {short}",
    "on-click": "hyprctl switchxkblayout current next",
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "َ°ˆˆ",
      "deactivated": "َ°ˆ‰",
    },
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "َ°‚‍",
      "none": "َ°‚œ",
      "dnd-notification": "َ°‚›",
      "dnd-none": "َ°‚›",
      "inhibited-notification": "َ°‚‍",
      "inhibited-none": "َ°‚œ",
      "dnd-inhibited-notification": "َ°‚›",
      "dnd-inhibited-none": "َ°‚œ",
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true,
  },
  "tray": {
    "icon-size": 16,
    "spacing": 8,
  },
  "clock": {
    "format": "َ°¥”  {:%H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%Y-%m-%d}",
  },
}
